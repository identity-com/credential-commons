{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://identity.com/schemas/claim-cvc:Medical.covid19-v1",
  "title": "claim-cvc:Medical.covid19-v1",
  "type": "object",
  "properties": {
    "vaccinations": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "additionalProperties": false
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "additionalProperties": false
    },
    "patient": {
      "type": "object",
      "properties": {
        "fullName": {
          "type": "string"
        },
        "dateOfBirth": {
          "type": "object",
          "properties": {
            "day": {
              "type": "number",
              "minimum": 1,
              "maximum": 31
            },
            "month": {
              "type": "number",
              "minimum": 1,
              "maximum": 12
            },
            "year": {
              "type": "number",
              "minimum": 1900
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}