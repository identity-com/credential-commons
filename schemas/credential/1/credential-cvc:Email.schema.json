{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://identity.com/schemas/credential-cvc:Email-v1",
  "title": "credential-cvc:Email-v1",
  "type": "object",
  "required": ["username", "domain"],
  "properties": {
    "username": {
      "type": "string"
    },
    "domain": {
      "type": "object",
      "required": ["tld", "name"],
      "properties": {
        "tld": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    }
  }
}
